#!/bin/bash
#
# https://fx.wtf/install

# TODO handle passing flags
file="$(readlink -f "${1:?Usage: fx <file>}")"
if [[ -r "$file" ]] ; then
  docker run \
    -u "$(id -u):$(id -g)" \
    -it \
    --rm \
    -v "$file:/file.json:ro" \
    -e FX_THEME=3 \
    antonmedv/fx "/file.json"
else
  echo "ERROR: ${1:-} not found" >&2
  exit 1
fi
